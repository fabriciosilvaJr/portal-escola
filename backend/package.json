{
  "name": "portal-escolar-backend",
  "version": "1.0.0",
  "description": "Backend do Portal Escolar",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
